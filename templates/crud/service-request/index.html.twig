{% extends 'crud/base.html.twig' %}

{% import 'crud/macros.html.twig' as m %}

{% block title %}
	{{ 'service_requests'|trans }}
{% endblock %}

{% block crud_content %}
	<h1>{{ 'service_requests'|trans }}</h1>

	<table class="table">
		<thead>
			<tr>
				<th>{{ 'crud.entity.default.id'|trans }}</th>
				<th>{{ 'crud.entity.default.room_number'|trans }}</th>
				<th>{{ 'crud.entity.default.created_by'|trans }}</th>
				<th>{{ 'crud.entity.default.schedule_at'|trans }}</th>
				<th>{{ 'crud.entity.default.status'|trans }}</th>
				<th>{{ 'crud.entity.default.created_at'|trans }}</th>
				<th>{{ 'crud.entity.default.updated_at'|trans }}</th>
				<th>{{ 'crud.table.header.actions'|trans }}</th>
			</tr>
		</thead>
		<tbody>
			{% for service_request in service_requests %}
				<tr>
					<td>{{ service_request.id }}</td>
					<td>{{ service_request.roomNumber }}</td>
					<td>{{ service_request.createdBy }}</td>
					<td>{{ service_request.scheduleAt ? service_request.scheduleAt|date('H:i') : '' }}</td>
					<td>{{ service_request.status.translationKey()|trans }}</td>
					<td>{{ service_request.createdAt ? service_request.createdAt|date('Y-m-d H:i:s') : '' }}</td>
					<td>{{ service_request.updatedAt ? service_request.updatedAt|date('Y-m-d H:i:s') : '' }}</td>
					<td>
						{{ m.list_action_button('crud_service_request_show',{'id': service_request.id},'crud.show') }}
						{{ m.list_action_button('crud_service_request_edit',{'id': service_request.id},'crud.edit') }}
					</td>
				</tr>
			{% else %}
				<tr>
					<td colspan="8">{{ 'crud.table.body.no_records_found'|trans }}</td>
				</tr>
			{% endfor %}
		</tbody>
	</table>
	{{ m.new_button('crud_service_request_new') }}
{% endblock %}
