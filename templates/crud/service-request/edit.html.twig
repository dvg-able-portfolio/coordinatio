{% extends 'crud/base.html.twig' %}

{% import 'crud/macros.html.twig' as m %}

{% block title %}
	{{ 'crud.edit_item'|trans({'%item%': 'service_request'|trans}) }}
{% endblock %}

{% block crud_content %}
	<h1>{{ 'crud.edit_item'|trans({'%item%': 'service_request'|trans}) }}</h1>

	{{ m.crud_form(form,'crud.update') }}

	<div
		class="d-flex justify-content-between align-items-center p-1 w-100">
		<!-- Left buttons -->
		<div class="d-flex gap-2">
			{{ m.back_button('crud_service_request_index') }}
		</div>

		<!-- Right buttons -->
		<div class="d-flex gap-2">
			{{ m.delete_button('crud_service_request_delete',service_request.id) }}
		</div>
	</div>

	<script type="module">
		import {listener} from 'service-request';
listener.listen();
	</script>
{% endblock %}
