{% extends 'crud/base.html.twig' %}

{% import 'crud/macros.html.twig' as m %}

{% block title %}
	{{ 'employees'|trans }}
{% endblock %}

{% block crud_content %}
	<h1>{{ 'employees'|trans }}</h1>

	<table class="table">
		<thead>
			<tr>
				<th>{{ 'crud.entity.default.id'|trans }}</th>
				<th>{{ 'crud.entity.default.name'|trans }}</th>
				<th>{{ 'crud.entity.default.role'|trans }}</th>
				<th>{{ 'crud.entity.default.login_token'|trans }}</th>
				<th>{{ 'crud.entity.default.created_at'|trans }}</th>
				<th>{{ 'crud.entity.default.updated_at'|trans }}</th>
				<th>{{ 'crud.table.header.actions'|trans }}</th>
			</tr>
		</thead>
		<tbody>
			{% for employee in employees %}
				<tr>
					<td>{{ employee.id }}</td>
					<td>{{ employee.name }}</td>
					<td>{{ employee.role }}</td>
					<td>{{ employee.loginToken }}</td>
					<td>{{ employee.createdAt ? employee.createdAt|date('Y-m-d H:i:s') : '' }}</td>
					<td>{{ employee.updatedAt ? employee.updatedAt|date('Y-m-d H:i:s') : '' }}</td>
					<td>
						{{ m.list_action_button('crud_employee_show',{'id': employee.id},'crud.show') }}
						{{ m.list_action_button('crud_employee_edit',{'id': employee.id},'crud.edit') }}
					</td>
				</tr>
			{% else %}
				<tr>
					<td colspan="7">{{ 'crud.table.body.no_records_found'|trans }}</td>
				</tr>
			{% endfor %}
		</tbody>
	</table>

	{{ m.new_button('crud_employee_new') }}
{% endblock %}
