<div id="flash-container" class="position-fixed top-0 start-50 translate-middle-x p-3" style="z-index: 9999">
	{% for type, messages in app.flashes %}
		{% for message in messages %}
			<div class="alert alert-{{ type }} alert-dismissible fade show" role="alert">
				{% if message.key is defined %}
					{% set translatedParams = {} %}
					{% for key, value in message.params %}
						{% if value is iterable %}
							{% set translated = [] %}
							{% for item in value %}
								{% set translated = translated|merge([item|trans]) %}
							{% endfor %}
							{% set translatedParams = translatedParams|merge({(key):  translated|join(', ') }) %}
						{% else %}
							{% set translatedParams = translatedParams|merge({(key):  value|trans }) %}
						{% endif %}
					{% endfor %}
					{{ message.key|trans(translatedParams)|raw }}
				{% else %}
					{{ message|trans }}
				{% endif %}
				<button type="button" class="btn-close" data-bs-dismiss="alert"></button>
			</div>
		{% endfor %}
	{% endfor %}
</div>
